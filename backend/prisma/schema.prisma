generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────── ENUMS ─────────────────

enum Role {
  ADMIN
  VIEWER
}

enum FieldType {
  PROPIO
  ALQUILADO
}

enum StockMovementType {
  HARVEST
  PURCHASE
  SALE
  TRANSFER
  ADJUSTMENT
  INTERNAL_CONSUMPTION
}

enum LivestockMovementType {
  INCOME
  SALE
  DEATH
  TRANSFER
  ADJUSTMENT
}

enum LivestockCategory {
  TERNEROS
  NOVILLOS
  VACAS
  TOROS
}

// V2 — seis categorías por sexo (additive, no reemplaza LivestockCategory)
enum LivestockCategoryV2 {
  TERNERO
  TERNERA
  NOVILLO
  VAQUILLONA
  TORO
  VACA
}

enum Currency {
  ARS
  USD
}

enum FinancialDirection {
  INCOME
  EXPENSE
}

enum ObligationType {
  RENT
  CREDIT
  SUPPLIER
  OTHER
}

enum ObligationStatus {
  PENDING
  PAID
}

enum PaymentMethod {
  CASH
  TRANSFER
  THIRD_PARTY_CHECK
  QUINTALES
  OTHER
}

enum LivestockType {
  TERNERO
  TERNERA
  NOVILLO
  VAQUILLONA
  TORO
  VACA
  FEEDLOT // mantenido por compatibilidad con datos históricos; no se expone en la API
}

enum TreatmentType {
  VACUNA
  BAÑO
  DESPARASITACION
  OTRO
}

enum ThirdPartyWorkType {
  SIEMBRA
  FUMIGACION
  COSECHA
  FERTILIZACION
  MOVIMIENTO_SUELO
}

enum ProviderType {
  INTERNO
  EXTERNO
}

enum ThirdPartyWorkStatus {
  PENDING
  PAID
  CANCELLED
}

// ───────────────── USERS ─────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ───────────────── FIELDS ─────────────────

model Field {
  id        String    @id @default(uuid())
  name      String
  type      FieldType
  createdAt DateTime  @default(now()) @map("created_at")

  lots           Lot[]
  leaseContracts LeaseContract[]

  @@map("fields")
}

// ───────────────── LOTS ─────────────────

model Lot {
  id        String   @id @default(uuid())
  fieldId   String   @map("field_id")
  surfaceHa Decimal  @map("surface_ha") @db.Decimal(10, 2)
  location  String?
  createdAt DateTime @default(now()) @map("created_at")

  field            Field              @relation(fields: [fieldId], references: [id])
  campaigns        Campaign[]
  stockMovements   StockMovement[]
  thirdPartyWorks  ThirdPartyWork[]

  @@map("lots")
}

// ───────────────── CAMPAIGNS ─────────────────

model Campaign {
  id        String   @id @default(uuid())
  lotId     String   @map("lot_id")
  year      Int
  crop      String
  createdAt DateTime @default(now()) @map("created_at")

  lot                Lot                 @relation(fields: [lotId], references: [id])
  stockMovements     StockMovement[]
  financialMovements FinancialMovement[]

  @@map("campaigns")
}

// ───────────────── STOCK MOVEMENTS ─────────────────

model StockMovement {
  id           String            @id @default(uuid())
  product      String
  movementType StockMovementType @map("movement_type")
  quantity     Decimal           @db.Decimal(14, 2)
  unit         String
  unitPrice    Decimal?          @map("unit_price") @db.Decimal(14, 2)
  notes        String?
  lotId        String?           @map("lot_id")
  campaignId   String?           @map("campaign_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  deletedAt    DateTime?         @map("deleted_at")

  lot                Lot?                @relation(fields: [lotId], references: [id])
  campaign           Campaign?           @relation(fields: [campaignId], references: [id])
  financialMovements FinancialMovement[]

  @@index([product])
  @@index([deletedAt])
  @@map("stock_movements")
}

// ───────────────── FINANCIAL MOVEMENTS ─────────────────

model FinancialMovement {
  id                     String             @id @default(uuid())
  direction              FinancialDirection
  category               String?
  amount                 Decimal            @db.Decimal(14, 2)
  currency               Currency
  exchangeRateAtCreation Decimal            @map("exchange_rate_at_creation") @db.Decimal(14, 6)
  baseCurrencyAmount     Decimal            @map("base_currency_amount") @db.Decimal(14, 2)
  paymentMethod          PaymentMethod?     @map("payment_method")
  reference              String?
  counterparty           String?
  notes                  String?

  stockMovementId String?        @map("stock_movement_id")
  stockMovement   StockMovement? @relation(fields: [stockMovementId], references: [id])

  campaignId String?   @map("campaign_id")
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([stockMovementId])
  @@index([campaignId])
  @@index([paymentMethod])
  @@index([deletedAt])
  @@map("financial_movements")
}

// ───────────────── LIVESTOCK MOVEMENTS ─────────────────

model LivestockMovement {
  id          String                @id @default(uuid())
  date        DateTime              @db.Date
  category    LivestockCategory
  categoryV2  LivestockCategoryV2?  @map("category_v2")
  type        LivestockMovementType
  quantity    Int
  totalPrice  Decimal?              @map("total_price") @db.Decimal(14, 2)
  notes       String?
  createdAt   DateTime              @default(now()) @map("created_at")
  deletedAt   DateTime?             @map("deleted_at")

  @@index([deletedAt])
  @@map("livestock_movements")
}

// ───────────────── LIVESTOCK HEALTH RECORDS ─────────────────

model LivestockHealthRecord {
  id            String        @id @default(uuid())
  date          DateTime      @db.Date
  livestockType LivestockType @map("livestock_type")
  treatmentType TreatmentType @map("treatment_type")
  quantity      Int
  appliesToAll  Boolean       @default(false) @map("applies_to_all")
  totalCost     Decimal?      @map("total_cost") @db.Decimal(14, 2)
  costPerHead   Decimal?      @map("cost_per_head") @db.Decimal(14, 2)
  cost          Decimal?      @db.Decimal(14, 2)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  deletedAt     DateTime?     @map("deleted_at")

  @@index([deletedAt])
  @@map("livestock_health_records")
}

// ───────────────── OBLIGATIONS ─────────────────

model Obligation {
  id                  String           @id @default(uuid())
  concept             String
  amount              Decimal          @db.Decimal(14, 2)
  dueDate             DateTime         @map("due_date") @db.Date
  type                ObligationType
  status              ObligationStatus
  financialMovementId String?          @map("financial_movement_id")
  createdAt           DateTime         @default(now()) @map("created_at")
  deletedAt           DateTime?        @map("deleted_at")

  @@index([deletedAt])
  @@map("obligations")
}

// ───────────────── EMPLOYEES / PAYROLL ─────────────────

model Employee {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  salaryPayments SalaryPayment[]
  salaryAdvances SalaryAdvance[]

  @@map("employees")
}

model SalaryPayment {
  id                  String    @id @default(uuid())
  employeeId          String    @map("employee_id")
  date                DateTime  @db.Date
  amount              Decimal   @db.Decimal(14, 2)
  notes               String?
  financialMovementId String?   @map("financial_movement_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  deletedAt           DateTime? @map("deleted_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([deletedAt])
  @@map("salary_payments")
}

model SalaryAdvance {
  id                  String    @id @default(uuid())
  employeeId          String    @map("employee_id")
  date                DateTime  @db.Date
  amount              Decimal   @db.Decimal(14, 2)
  notes               String?
  financialMovementId String?   @map("financial_movement_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  deletedAt           DateTime? @map("deleted_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([deletedAt])
  @@map("salary_advances")
}

// ───────────────── THIRD PARTY WORKS ─────────────────

model ThirdPartyWork {
  id                  String               @id @default(uuid())
  date                DateTime             @db.Date
  workType            ThirdPartyWorkType   @map("work_type")
  lotId               String               @map("lot_id")
  contractor          String
  paymentMethod       PaymentMethod        @map("payment_method")
  amount              Decimal?             @db.Decimal(14, 2)
  currency            Currency?
  quintales           Decimal?             @db.Decimal(14, 2)
  grainType           String?              @map("grain_type")
  reference           String?
  notes               String?
  providerType        ProviderType         @default(EXTERNO) @map("provider_type")
  status              ThirdPartyWorkStatus @default(PENDING)
  financialMovementId String?              @map("financial_movement_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  deletedAt           DateTime?            @map("deleted_at")

  lot Lot @relation(fields: [lotId], references: [id])

  @@index([lotId])
  @@index([deletedAt])
  @@map("third_party_works")
}

// ───────────────── LEASE CONTRACTS ─────────────────

model LeaseContract {
  id             String    @id @default(uuid())
  fieldId        String    @map("field_id")
  year           Int
  totalQuintales Decimal   @map("total_quintales") @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  field      Field          @relation(fields: [fieldId], references: [id])
  deliveries LeaseDelivery[]

  @@index([fieldId])
  @@index([deletedAt])
  @@map("lease_contracts")
}

model LeaseDelivery {
  id                  String        @id @default(uuid())
  contractId          String        @map("contract_id")
  date                DateTime      @db.Date
  quintales           Decimal       @db.Decimal(14, 2)
  amountARS           Decimal       @map("amount_ars") @db.Decimal(14, 2)
  paymentMethod       PaymentMethod @map("payment_method")
  reference           String?
  notes               String?
  financialMovementId String?       @map("financial_movement_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  deletedAt           DateTime?     @map("deleted_at")

  contract LeaseContract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@index([deletedAt])
  @@map("lease_deliveries")
}
